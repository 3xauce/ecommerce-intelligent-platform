# Base de données
# Port 5433 = celui exposé par notre docker-compose.yml (5432 est volontairement
# évité pour ne pas entrer en conflit avec une éventuelle autre instance locale).
# Si tu utilises un PostgreSQL natif (hors Docker) sur le port par défaut,
# remplace 5433 par 5432 ci-dessous.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ecommerce_db
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis
# Port 6380 = celui exposé par notre docker-compose.yml (6379 évité pour la
# même raison que le port PostgreSQL ci-dessus).
REDIS_URL=redis://localhost:6380

# Planification automatique du scraping (format cron), optionnelle.
# Ex: "0 * * * *" = toutes les heures ; "0 6 * * *" = tous les jours à 6h.
# Laisser vide pour désactiver.
SCRAPING_CRON=

# Microservice IA (ai-module). En local : python app.py sur le port 8010.
# Dans Docker : http://ai:8000 (surchargé par docker-compose.yml).
AI_SERVICE_URL=http://localhost:8010

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_password

# Limite de requêtes API par IP sur 15 minutes (anti-abus)
RATE_LIMIT_MAX=600

# App
# Port 5000 est réservé par Windows/Hyper-V sur certaines machines
# (netsh interface ipv4 show excludedportrange) et provoque une erreur
# EACCES au démarrage. 5001 est utilisé par défaut pour l'éviter.
# (Ces valeurs sont pour un lancement manuel hors Docker ; docker-compose.yml
# surcharge PORT/FRONTEND_URL avec les ports du frontend/backend conteneurisés.)
PORT=5001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Google Sign-In (optionnel — bouton masque si absent)
# Cree un OAuth Client ID "Web application" sur https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

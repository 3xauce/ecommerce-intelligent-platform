# Connexion PostgreSQL (mêmes données que le backend)
# Hors Docker : port 5433 (voir docker-compose.yml). Dans Docker : postgres:5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ecommerce_db

# File de jobs Redis alimentée par le backend
# Hors Docker : port 6380. Dans Docker : redis:6379.
REDIS_URL=redis://localhost:6380

# Proxies rotatifs (optionnel) : URLs séparées par des virgules
# PROXY_LIST=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
PROXY_LIST=

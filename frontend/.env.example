# URL de l'API backend (préfixe /api inclus)
VITE_API_URL=http://localhost:5001/api

# Origine du backend (sans /api), utilisée pour résoudre les URLs d'images
# uploadées (/uploads/products/...)
VITE_API_ORIGIN=http://localhost:5001

# Clé publique Stripe (pk_test_...), nécessaire pour la page de paiement
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
